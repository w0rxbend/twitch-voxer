# ── Required ──────────────────────────────────────────────────────────────────
# Twitch application credentials (https://dev.twitch.tv/console/apps)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Bot account OAuth tokens
TWITCH_ACCESS_TOKEN=
TWITCH_REFRESH_TOKEN=

# ── Optional: bot identity ────────────────────────────────────────────────────
# Twitch login name of the bot account (default: worxbend)
TWITCH_BOT_USERNAME=worxbend

# ── Optional: paths ───────────────────────────────────────────────────────────
# JSON file storing username → voice assignments (default: data/voices.json)
VOXER_DB_PATH=data/voices.json

# JSON file storing username → last-message timestamps (default: data/timestamps.json)
VOXER_TIMESTAMPS_DB_PATH=data/timestamps.json

# Directory for generated MP3 files served to the overlay (default: audio)
VOXER_AUDIO_DIR=audio

# JSON file of scheduled chat messages (default: data/messages.json)
VOXER_MESSAGES_PATH=data/messages.json

# Directory of custom voice JSON files (default: voices)
VOXER_VOICES_DIR=voices

# pickledb file written by scripts/fetch_emotes.py (default: emotes/emotes.db)
VOXER_EMOTES_DB_PATH=emotes/emotes.db

# ── Optional: server ──────────────────────────────────────────────────────────
VOXER_SERVER_HOST=0.0.0.0
VOXER_SERVER_PORT=8080

# ── Optional: scheduler ───────────────────────────────────────────────────────
# Seconds between scheduled chat messages (default: 600)
VOXER_SCHEDULER_INTERVAL=600
# Seconds to wait before first scheduled message after startup (default: 10)
VOXER_SCHEDULER_INITIAL_DELAY=10

# ── Optional: TTS behaviour ───────────────────────────────────────────────────
# Comma-separated list of usernames that never receive the "X says:" prefix
VOXER_NO_ANNOUNCE_USERS=worxbend

# Seconds of silence before re-announcing a user's name (default: 300 = 5 min)
VOXER_ANNOUNCE_WINDOW_SECS=300

# Comma-separated MP3 paths played for emote-only messages
VOXER_EMOTE_SOUND_PATHS=emotes/slack-message.mp3,emotes/discord.mp3

# ── Optional: logging ─────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
VOXER_LOG_LEVEL=INFO
